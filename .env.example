# SmartExam Builder runs with deterministic mock LLM outputs by default.
# Set SMARTEXAM_USE_MOCK_LLM=false and provide an API key to use OpenAI.

SMARTEXAM_USE_MOCK_LLM=true
SMARTEXAM_OPENAI_MODEL=gpt-4o-mini
SMARTEXAM_OPENAI_TEMPERATURE=0.2

# Either variable name is supported:
OPENAI_API_KEY=
# SMARTEXAM_OPENAI_API_KEY=

